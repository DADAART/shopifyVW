  <section class="SlideRealisations splideBestCredence">
    <h2>Meilleures ventes</h2>
    <div id="splideBestCredence" class="splide">
      <div class="splide__track">
        <ul class="splide__list">
          {% for product in collections['credences-adhesives-bestsellers'].products %}
            {% for tag in product.tags %}
              {% if tag contains '#' %}
                {% assign dataColor = tag %}
              {% endif %}
            {% endfor %}
            {% for tag in product.tags %}
              {% if tag contains '#' %}
                <li class="splide__slide" style="background-color:{{ dataColor }};">
                  <a href="{{ product.url }}">
                    <img
                      alt="Vinyl Way {{ product.title }}"
                      loading="lazy"
                      src="{{ product.images[0] | img_url: '500x' }}"
                    >
                  </a>
                  <div>
                    <span>{{ product.title }}</span>
                    <a class="btn btn_3" href="{{ product.url }}">Voir</a>
                  </div>
                </li>
              {% endif %}
            {% endfor %}
          {% endfor %}
        </ul>
      </div>
    </div>
  </section>

