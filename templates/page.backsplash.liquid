  <style>
        .coverCredence {
          background-image:url('https://cdn.shopify.com/s/files/1/0567/1220/0371/files/bgCredence.jpg?v=1700458223');
          background-repeat:repeat;
          background-size: contain;
          height:300px;
          display: flex;
          justify-content: center;
          align-items: center;
          position: relative;
          max-width:100%;
          overflow: hidden;
        }
        .coverCredence > div img {
          visibility:hidden;
          opacity:0;
          height:100%;
          width: auto;
        }

    /*  */
        .coverCredence > div {
        position: absolute;
        height: 100%;
          width:100%;
          background-image:url('https://vinyl-way.com/cdn/shop/products/77718.jpg?v=1700125746');
          background-position:left;
          background-size:cover;
        left: 65%;
        -webkit-animation: coverCredence 6s ease-in-out infinite;
        animation: coverCredence 6s ease-in-out infinite;
        overflow: hidden;
      transition: 0.5s;
        clip-path:polygon(0 0, 100% 0, 100% 100%, 0 100%, 0px 100%, 0px 300px)
        }
        .coverCredence > div .shadow {
  z-index:4;
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0px;
  height: 0px;
  box-shadow: 5px -5px 10px -6px #000;
  transition: 0.5s;
background: linear-gradient(45deg, rgba(255,255,255,0) 0%, rgba(0,0,0,0) 50%, rgba(139,139,139,1) 50%, rgba(139,139,139,1) 65%, rgba(255,255,255,1) 100%);
        -webkit-animation: coverCredenceShadow 6s ease-in-out infinite;
        animation: coverCredenceShadow 6s ease-in-out infinite;
}
    /*  */
    
        .coverCredence h4 {
        margin: auto;
        font-size: calc(20px + 1.5vw);
        padding-right: 23%;
        }
        .coverCredence h4 strong {
          font-weight:900;
          font-size:120%;
          display:block;
        }

        @keyframes coverCredence {
         0%, 100% {
        transform: translateX(0);
        background-image: url('https://vinyl-way.com/cdn/shop/products/79697-40x198_e9c518ab-977d-4734-8819-8ae73854483d.jpg?v=1707290413');
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%, 200px 100%, 0px 100px)
    }

    50% {
        transform: translateX(-30%); /* Ajustez cette valeur pour la distance de translation */
        background-image: url('https://vinyl-way.com/cdn/shop/products/60964-40x198_ccc19edc-49a2-422a-9b94-32bf2ef272cc.jpg?v=1707290765');
        clip-path:polygon(0 0, 100% 0, 100% 100%, 0 100%, 0px 100%, 0px 300px)
    }

    80% {
        transform: translateX(0);
        background-image: url('https://vinyl-way.com/cdn/shop/products/77721-40x198_a55869ac-70ff-46ff-ac81-9a01676891f0.jpg?v=1707290780');
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%, 200px 100%, 0px 100px)
    }
        }
        @keyframes coverCredenceShadow {
         0%, 100% {
  width: 200px;
  height: 200px;
    }

    50% {
  width: 0px;
  height: 0px;
    }

    80% {
  width: 200px;
  height: 200px;
    }
        }
  </style>

