<script src="https://code.jquery.com/ui/1.12.1/jquery-ui.min.js"></script>
<script>
$(document).ready(function(){
    var imagesSets = [
        {
            bgColor: "#d8d6d2",
            images: [
                "https://cdn.shopify.com/s/files/1/0567/1220/0371/files/MES_Camping_Car_3D_70130_0f9c95fb-a838-463c-90ed-3a1cdea2b61c_650x.png?v=1699858568",
                "https://cdn.shopify.com/s/files/1/0567/1220/0371/files/70130-camping_car_salon_900x_e70a0f70-6021-4107-94d8-865726c5dda4_650x.webp?v=1699857300",
                "https://cdn.shopify.com/s/files/1/0567/1220/0371/files/70130-camping_car_sdb_900x_3a6daae6-0923-4b24-9926-2dc5932e6873_650x.webp?v=1699857299"
            ],
            href: "{{ localUrl }}/products/adhesive-tiles-claire/+camping_car_salon"
        },
        {
            bgColor: "#c2cfc0",
            images: [
                "https://cdn.shopify.com/s/files/1/0567/1220/0371/files/MES_Camping_Car_3D_60819_e671c45e-3008-4ea8-a42f-82e57d54190b_650x.png?v=1699858568",
                "https://cdn.shopify.com/s/files/1/0567/1220/0371/files/60819-camping_car_salon_900x_cfd9a222-4eb8-4492-8c27-5e42fdf75764_650x.webp?v=1699857301",
                "https://cdn.shopify.com/s/files/1/0567/1220/0371/files/60819-camping_car_chambre_900x_1b5e5fed-b545-43b8-b18e-3a833c489580_650x.webp?v=1699857300"
            ],
            href: "{{ localUrl }}/products/adhesive-tiles-alice/+camping_car_salon"
        },
        {
            bgColor: "#767d6f",
            images: [
                "https://cdn.shopify.com/s/files/1/0567/1220/0371/files/MES_Camping_Car_3D_72983_53f54dbe-9fb3-41da-938d-756c85e1bef0_650x.png?v=1699858568",
                "https://cdn.shopify.com/s/files/1/0567/1220/0371/files/72983-camping_car_salon_900x_b04f067a-5601-4860-b5c2-88fef4d2672d_650x.webp?v=1699857300",
                "https://cdn.shopify.com/s/files/1/0567/1220/0371/files/72983-camping_car_sdb_900x_c954c6b1-bdba-499f-9f22-359c573e9786_650x.webp?v=1699857299"
            ],
            href: "{{ localUrl }}/products/adhesive-tiles-massa/+camping_car_salon"
        },
    ];

    var currentSet = 0;

    function changeImages() {
        currentSet = (currentSet + 1) % imagesSets.length;
        var set = imagesSets[currentSet];

        $('#slideCc > div:nth-child(1)').animate({backgroundColor: set.bgColor}, 'slow');
        $('#slideCc').data('href', set.href);

        $('#slideCc img').each(function(index){
            $(this).fadeOut('slow', function() {
                $(this).attr('src', set.images[index]).fadeIn('slow');
            });
        });
    }

    setInterval(changeImages, 3000); // Change every 3000 milliseconds (3 seconds)

    // Gestionnaire de clics pour #slideCc
    $('#slideCc').on('click', function() {
        window.location.href = $(this).data('href');
    });
});
</script>



