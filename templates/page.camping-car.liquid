<style>
        .template-index .camping_car_1, .template-index .camping_car_2 {
          display:flex;
          gap: 1rem;
          padding:1rem;          
    flex-direction: column;
        }
        .template-index .camping_car_1 > * > * > * , .template-index .camping_car_2 > * > * > * {
          width:100%;
        }
        .template-index .camping_car_1 > div:nth-child(1), .template-index .camping_car_2 > div:nth-child(2) {
          background-color: #f5f5f5;
          display:flex;
          align-items:center;
          justify-content: center;
          width: 100%;
          flex: 50%;
        }
        .template-index .camping_car_1 > div:nth-child(1)  > div, .template-index .camping_car_2 > div:nth-child(2) > div {
          display:flex;
          align-items:flex-start;
          justify-content: center;
          padding: 1rem;          
    flex-direction: column;
      width: max-content;
          max-width:100%;
          margin:auto;
        }
        .template-index .camping_car_1 > div:nth-child(1) h1 {
          font-weight: 900;
          font-size:26px;
          text-align:left;
        }
        .template-index .camping_car_1 > div:nth-child(1) h1 strong {
          display:block;
          font-size:34px;
          font-weight: 900;
        }
        .template-index .camping_car_1 > div:nth-child(1) p, .template-index .camping_car_2 p {
          max-width: 500px;
        }
  
  .template-index .camping_car_1 .btn , .template-index .camping_car_2 .btn {
    margin-left: 0;
  }
        .template-index .Presentation {
      padding: 0rem;
      padding-bottom: 1rem;
      padding-top: 1.5rem;
        }

  .template-index .btn_2 {
    margin: 0 auto;
    font-weight: normal;
    text-transform: uppercase;
    padding: 0.5rem 4rem;
    display: block;
    margin-top: 2rem;
    color: #000;
    border: 2px solid #000;
    width: max-content;
    max-width: 100%;
  }

  .template-index .btn_2:hover {
      background-color: #000;
      color: #fff;
  }
  .template-index .btn_3 {
      margin: auto;
      font-weight: normal;
      text-transform: uppercase;
      padding: 0.5rem 4rem;
      display: block;
      margin-top: 2rem;
      color: #fff;
      border: 2px solid #fff;
      width: max-content;
    max-width: 100%;
  }

  .template-index .btn_3:hover {
      background-color: #fff;
      color: #000 !important;
  }
  .template-index .camping_car_1 > div:nth-child(2) {
    display:flex;
    gap: 1rem;
    flex-wrap : wrap;
    cursor:pointer;
  }

  .template-index .camping_car_1 > div:nth-child(2) > * {
    flex: 45%;
  }
  .template-index .camping_car_1 > div:nth-child(2) > div:first-child {
    flex: 100%;
      position: relative;
      min-height: 250px;
  }

        .template-index .camping_car_1 > div:nth-child(2) > div:first-child img {
       position: absolute;
      height: auto;
      bottom: -1rem;
      left: 50%;
      transform: translateX(-50%);
      width: 90%;
      max-width: 400px;
        }
       .template-index .camping_car_2 video {
         width: 100%;
       }
       .template-index .camping_car_2 > div:nth-child(2) {
         background-color: #65aeaa;
       }
       .template-index .camping_car_2 > div:nth-child(2) > div > * {
         color: #fff;
       }
       .template-index .camping_car_2 h3 {
         text-align:left;
       }

  /* MEDIA SCREEN */
@media only screen and (min-width: 1025px) {
.template-index .camping_car_1, .template-index .camping_car_2 {
  flex-direction : row;
}
  .template-index .Presentation {
    height: 100%;
}
  .template-index .Presentation .contentPresentation {
    position: relative;
  }
  .template-index .camping_car_1 > div:nth-child(2) > div:first-child {
    flex: 100%;
      position: relative;
      min-height: 400px;
  }
.template-index .camping_car_1 > div:nth-child(1) h1,  .template-index .camping_car_2 h3 {
          font-size: 57px;
    text-align: left;
    width: max-content;
    max-width: 100%;
        }
 .template-index .camping_car_2 h3 {
          font-size: 45px;
        }
        .template-index .camping_car_1 > div:nth-child(1) h1 strong {
          font-size:72px;
        }
.template-index .camping_car_1 > div:nth-child(1) p {
          font-size:32px;
  font-weight: bold;
        }
.template-index .camping_car_2 > div:nth-child(2) p {
          font-size:20px;
  font-weight: bold;
    max-width: 610px;
        }
        .template-index .camping_car_1 > div:nth-child(2) > div:first-child img {
      max-width:700px;
        }
  .template-index .camping_car_2 video {
    max-height: 70vh;
}
}
  
</style>

