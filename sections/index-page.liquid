{{ 'index-page.css' | asset_url | stylesheet_tag }}
{{ 'index-page.js' | asset_url | script_tag }}

{% if request.locale.iso_code contains "fr" %}
  {% assign localUrl = "" %}
{% else %}
  {% capture localUrl %}/{{ request.locale.iso_code }}{% endcapture %}
{% endif %}

<div class="vw-home">

  <section class="vw-hero">
    <video class="vw-hero__video" autoplay muted loop playsinline
      poster="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
      alt="{{ 'vw.index.presentation.video_alt' | t }}">
      {{ 'vw.index.presentation.video_error' | t }}
    </video>
    <div class="vw-hero__overlay"></div>

    <div class="vw-hero__inner">
      <span class="vw-hero__eyebrow">— Made in France · Depuis 2018</span>
      <h1 class="vw-hero__title">
        <span>Réinvente</span>
        <span>tes murs.</span>
      </h1>
      <p class="vw-hero__sub">
        Carreaux adhésifs, papiers peints &amp; crédences.<br>
        Pose en 1h. Sans travaux. Sans regrets.
      </p>
      <div class="vw-hero__ctas">
        <a class="vw-btn vw-btn--primary" href="{{ localUrl }}/collections/{{ 'vw.url.carreaux-adhesifs' | t }}/">
          Découvrir les motifs
        </a>
        <a class="vw-btn vw-btn--ghost" href="#vw-how">
          Comment ça marche
        </a>
      </div>
    </div>

    <ul class="vw-hero__stats">
      <li><strong>200+</strong><span>motifs uniques</span></li>
      <li><strong>1h</strong><span>chrono pour poser</span></li>
      <li><strong>0</strong><span>travaux requis</span></li>
      <li><strong>100%</strong><span>fabriqué en France</span></li>
    </ul>
  </section>

  <section class="vw-marquee" aria-hidden="true">
    <div class="vw-marquee__track">
      {% for i in (1..2) %}
      <span>Made in France</span><span class="vw-marquee__star">✦</span>
      <span>Pose en 1h</span><span class="vw-marquee__star">✦</span>
      <span>+200 motifs</span><span class="vw-marquee__star">✦</span>
      <span>Sans travaux</span><span class="vw-marquee__star">✦</span>
      <span>Livraison offerte</span><span class="vw-marquee__star">✦</span>
      <span>Imperméable</span><span class="vw-marquee__star">✦</span>
      {% endfor %}
    </div>
  </section>

  <section class="vw-manifesto">
    <div class="vw-manifesto__text">
      <span class="vw-eyebrow">Le concept</span>
      <h2 class="vw-display">
        Change.<br>
        Décore.<br>
        <em>Sans travaux.</em>
      </h2>
      <p>
        Vinyl Way, c'est le revêtement adhésif nouvelle génération : pensé en France,
        fabriqué en France, livré chez toi. Tu colles, tu lisses, tu profites.
        Une transformation radicale, sans poussière, sans casse, sans compromis.
      </p>
      <a class="vw-link-arrow" href="{{ localUrl }}/pages/{{ 'vw.url.installation' | t }}">
        Voir l'esprit Vinyl Way <span aria-hidden="true">→</span>
      </a>
    </div>
    <div class="vw-pillars">
      <div class="vw-pillar vw-pillar--accent">
        <span class="vw-pillar__num">01</span>
        <h3>Sans travaux</h3>
        <p>Tu poses sur tes anciens carreaux. Pas de marteau, pas d'artisan.</p>
      </div>
      <div class="vw-pillar">
        <span class="vw-pillar__num">02</span>
        <h3>Made in France</h3>
        <p>Imprimés et découpés dans nos ateliers, à côté de chez toi.</p>
      </div>
      <div class="vw-pillar">
        <span class="vw-pillar__num">03</span>
        <h3>+200 motifs</h3>
        <p>Zellige, terracotta, marbre, géométrique, mono… il y a forcément le tien.</p>
      </div>
      <div class="vw-pillar vw-pillar--accent">
        <span class="vw-pillar__num">04</span>
        <h3>Pose en 1h</h3>
        <p>Auto-adhésif, repositionnable. Tu commences le matin, tu dînes dessus le soir.</p>
      </div>
    </div>
  </section>

  <section class="vw-collections">
    <div class="vw-section-head">
      <div>
        <span class="vw-eyebrow">Nos collections</span>
        <h2 class="vw-display vw-display--md">200+ motifs.<br>Une seule règle&nbsp;: te plaire.</h2>
      </div>
      <a class="vw-link-arrow" href="{{ localUrl }}/collections/{{ 'vw.url.carreaux-adhesifs' | t }}/">
        Tout voir <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="vw-bento">
      {% assign priority_handles = 'zelliges,carreaux-marocains,marbre,carreaux-de-ciment,terra,bois,couleurs-unies,carreaux-de-metro,mosaique,beton,brique' | split: ',' %}
      {% assign bento_used = '' %}
      {% assign bento_count = 0 %}

      {%- for handle in priority_handles -%}
        {%- if bento_count >= 6 -%}{%- break -%}{%- endif -%}
        {%- assign col = collections[handle] -%}
        {%- if col and col.products.size > 0 -%}
          <a class="vw-bento__cell{% if bento_count == 0 %} vw-bento__cell--feature{% endif %}"
             href="{{ localUrl }}/collections/{{ 'vw.url.carreaux-adhesifs-collections' | t }}/#{{ col.handle }}">
            <img loading="lazy"
                 alt="Vinyl Way — Collection {{ col.title }}"
                 src="{{ col.products.first.featured_image | img_url: '900x' }}">
            <div class="vw-bento__label">
              <span class="vw-bento__kicker">Collection</span>
              <h3>{{ col.title }}</h3>
              <span class="vw-bento__cta">Explorer →</span>
            </div>
          </a>
          {%- assign bento_used = bento_used | append: ',' | append: col.handle -%}
          {%- assign bento_count = bento_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if bento_count < 6 -%}
        {%- for col in collections -%}
          {%- if bento_count >= 6 -%}{%- break -%}{%- endif -%}
          {%- unless bento_used contains col.handle -%}
            {%- if col.products.size > 0 and col.handle != 'all' and col.handle != 'frontpage' -%}
              <a class="vw-bento__cell{% if bento_count == 0 %} vw-bento__cell--feature{% endif %}"
                 href="{{ localUrl }}/collections/{{ col.handle }}">
                <img loading="lazy"
                     alt="Vinyl Way — Collection {{ col.title }}"
                     src="{{ col.products.first.featured_image | img_url: '900x' }}">
                <div class="vw-bento__label">
                  <span class="vw-bento__kicker">Collection</span>
                  <h3>{{ col.title }}</h3>
                  <span class="vw-bento__cta">Explorer →</span>
                </div>
              </a>
              {%- assign bento_count = bento_count | plus: 1 -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </section>

  <section class="vw-bestsellers">
    <div class="vw-section-head vw-section-head--center">
      <span class="vw-eyebrow">Les incontournables</span>
      <h2 class="vw-display vw-display--md">Les motifs<br>les plus chouchoutés.</h2>
    </div>

    <div id="splideProducts" class="splide vw-product-rail">
      <div class="splide__track">
        <ul class="splide__list">
          {% for product in collections.carreaux-adhesifs-bestsellers.products limit: 12 %}
            {% assign dataColor = '' %}
            {% for tag in product.tags %}
              {% if tag contains '#' %}
                {% assign dataColor = tag %}
              {% endif %}
            {% endfor %}
            <li class="splide__slide vw-product-card" {% if dataColor != '' %}data-color="{{ dataColor }}"{% endif %}>
              <a href="{{ product.url }}">
                <div class="vw-product-card__media">
                  <img loading="lazy"
                       alt="{{ 'vw.index.best.carreau_alt' | t }} Vinyl Way {{ product.title }}"
                       src="{{ product.images[1] | img_url: '600x' }}">
                </div>
                <div class="vw-product-card__body">
                  <span class="vw-product-card__title">{{ product.title }}</span>
                  <span class="vw-product-card__price">{{ product.price | money }}</span>
                </div>
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>

    <div class="vw-section-foot">
      <a class="vw-btn vw-btn--dark"
         href="{{ localUrl }}/collections/{{ 'vw.url.carreaux-adhesifs-bestsellers' | t }}/">
        Voir tous les best-sellers
      </a>
    </div>
  </section>

  <section class="vw-how" id="vw-how">
    <div class="vw-how__title">
      <span class="vw-eyebrow">Mode d'emploi</span>
      <h2 class="vw-display">
        Pose en 1h.<br>
        <em>Chrono.</em>
      </h2>
    </div>

    <div class="vw-how__grid">
      <div class="vw-how__media">
        <video id="videoInstall"
               poster="https://cdn.shopify.com/s/files/1/0567/1220/0371/files/poster-site-web-comment-poser-ses-carreaux-adhesifs-vinyl-way.jpg?v=1670489425"
               muted loop playsinline
               alt="{{ 'vw.index.install.video_alt' | t }}">
          <source src="https://cdn.shopify.com/videos/c/o/v/175cfeafb8c34a6893392ecf568d9285.mp4" type="video/mp4">
          {{ 'vw.index.presentation.video_error' | t }}
        </video>
        <button type="button" class="vw-how__play" id="btnInstall" aria-label="Lancer la vidéo">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="40" height="40">
            <path d="m15.5 0.932-4.3 4.38 14.5 14.6-14.5 14.5 4.3 4.4 14.6-14.6 4.4-4.3-4.4-4.4-14.6-14.6z"></path>
          </svg>
        </button>
      </div>

      <ol class="vw-steps">
        <li>
          <span class="vw-steps__num">01</span>
          <h3>{{ 'vw.index.install.list.li1.title' | t }}</h3>
          <p>{{ 'vw.index.install.list.li1.text' | t }}</p>
        </li>
        <li>
          <span class="vw-steps__num">02</span>
          <h3>{{ 'vw.index.install.list.li2.title' | t }}</h3>
          <p>{{ 'vw.index.install.list.li2.text1' | t }}. {{ 'vw.index.install.list.li2.text2' | t }}.</p>
        </li>
        <li>
          <span class="vw-steps__num">03</span>
          <h3>{{ 'vw.index.install.list.li3.title' | t }}</h3>
          <p>{{ 'vw.index.install.list.li3.text' | t }}</p>
        </li>
      </ol>
    </div>
  </section>

  <section class="vw-press">
    <span class="vw-eyebrow">Vu dans</span>
    <div class="vw-press__marquee" aria-hidden="true">
      <div class="vw-press__track">
        {% for i in (1..2) %}
        <img loading="lazy" alt="Castorama" src="https://cdn.shopify.com/s/files/1/0567/1220/0371/files/Castorama_Logo.png?v=1667830799">
        <img loading="lazy" alt="Maison &amp; Objet" src="https://cdn.shopify.com/s/files/1/0567/1220/0371/files/MaisonObjet-1line-logotype_black.png?v=1667831417">
        <img loading="lazy" alt="Salon Ambiente" src="https://cdn.shopify.com/s/files/1/0567/1220/0371/files/ambiente-datum-2020.png?v=1667830799">
        <img loading="lazy" alt="Made In France" src="https://cdn.shopify.com/s/files/1/0567/1220/0371/files/mif-2.png?v=1667831417">
        <img loading="lazy" alt="Marie Claire Maison" src="https://cdn.shopify.com/s/files/1/0567/1220/0371/files/logo.png?v=1635941585">
        <img loading="lazy" alt="Le Journal des Femmes" src="https://cdn.shopify.com/s/files/1/0567/1220/0371/files/logo-jdf.png?v=1635941585">
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="vw-wall">
    <div class="vw-section-head">
      <div>
        <span class="vw-eyebrow">Vos transformations</span>
        <h2 class="vw-display vw-display--md">#VinylWay</h2>
      </div>
      <p class="vw-wall__sub">Des milliers d'intérieurs métamorphosés. Le tien sera le prochain&nbsp;?</p>
    </div>

    <div class="vw-wall__grid">
      {% assign wall_imgs = 'client1,client2,client3,client4,client5,client6,client7,client8,client9,client10,client11,client12,client13' | split: ',' %}
      {% for img in wall_imgs %}
        <figure class="vw-wall__cell">
          <img loading="lazy"
               alt="{{ 'vw.index.realisations.img_alt' | t }}"
               src="https://cdn.shopify.com/s/files/1/0567/1220/0371/files/{{ img }}.jpg">
        </figure>
      {% endfor %}
    </div>
  </section>

  <section class="vw-dada">
    <div class="vw-dada__head">
      <span class="vw-eyebrow vw-eyebrow--light">La marque sœur</span>
      <h2 class="vw-display vw-display--md vw-text-light">DADA ART</h2>
      <p class="vw-text-light">
        Tapis vinyle, papiers peints, affiches…<br>
        Notre nouvelle marque 100&nbsp;% imaginée et fabriquée en France.
      </p>
    </div>

    <div id="splideDada" class="splide vw-dada__rail">
      <div class="splide__track">
        <ul class="splide__list">
          <li class="splide__slide">
            <a href="https://dada-art.fr/collections/tapis-vinyle" target="_blank" rel="noopener">
              <img loading="lazy" alt="Tapis vinyle" src="https://dada-art.fr/cdn/shop/files/032879CC_1_ba00d954-93b3-4e2a-b4ae-5f539fcdf872.jpg">
              <span>Tapis vinyle</span>
            </a>
          </li>
          <li class="splide__slide">
            <a href="https://dada-art.fr/collections/set-de-table" target="_blank" rel="noopener">
              <img loading="lazy" alt="Set de table" src="https://dada-art.fr/cdn/shop/files/048808VD_1_9521ea73-011f-4709-89e0-f70260d02c9d.jpg">
              <span>Set de table</span>
            </a>
          </li>
          <li class="splide__slide">
            <a href="https://dada-art.fr/collections/credence-aluminium" target="_blank" rel="noopener">
              <img loading="lazy" alt="Crédence Aluminium" src="https://dada-art.fr/cdn/shop/files/id_23617_slide_1_mes_mix1_display_neutre.jpg">
              <span>Crédence Aluminium</span>
            </a>
          </li>
          <li class="splide__slide">
            <a href="https://dada-art.fr/collections/papier-peint" target="_blank" rel="noopener">
              <img loading="lazy" alt="Papier peint" src="https://dada-art.fr/cdn/shop/files/id_PPA90344-95x140_slide_1_mes_adulte1.jpg">
              <span>Papier peint</span>
            </a>
          </li>
          <li class="splide__slide">
            <a href="https://dada-art.fr/collections/toile-imprimee" target="_blank" rel="noopener">
              <img loading="lazy" alt="Toile encadrée" src="https://dada-art.fr/cdn/shop/files/id_57432_type_toile_cadre_naturel_slide_1_format_60x90_e406985e-9f56-4ff7-9663-73ea7d70978f.webp">
              <span>Toile encadrée</span>
            </a>
          </li>
          <li class="splide__slide">
            <a href="https://dada-art.fr/collections/affiche" target="_blank" rel="noopener">
              <img loading="lazy" alt="Affiche" src="https://dada-art.fr/cdn/shop/files/id_23278_type_affiche_cadre_sans_slide_1_format_40x50_817da48e-d85a-4116-8538-d61a990a33d2.webp">
              <span>Affiche</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <div class="vw-reviews-widget">
    <div class="grc-site-iframe" data-type="horizontal"></div>
  </div>

  <section class="vw-cta-final">
    <h2 class="vw-display vw-display--xl">
      Prêt à<br>transformer&nbsp;?
    </h2>
    <a class="vw-btn vw-btn--primary vw-btn--lg"
       href="{{ localUrl }}/collections/{{ 'vw.url.carreaux-adhesifs' | t }}/">
      Choisir mes motifs <span aria-hidden="true">→</span>
    </a>
  </section>

</div>
