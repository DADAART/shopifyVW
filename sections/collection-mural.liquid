{{ 'collection-page.css' | asset_url | stylesheet_tag }}
{{ 'collection-page.js' | asset_url | script_tag }}

{% if request.locale.iso_code contains 'fr' %}
  {% assign localUrl = '' %}
{% else %}
  {% capture localUrl %}/{{ request.locale.iso_code }}{% endcapture %}
{% endif %}

<div>
  <div class="popupPreview">
    <div class="popupPreviewBg popupPreviewHide"></div>
    <div
      class="popupPreviewContent"
      role="img"
      alt="Mise en situation du carreau adhésif dans une maison. Adapté à toutes vos pièces"
    >
      <span class="popupPreviewHide">x</span>
      <div>
        <div></div>
        <a data-href="#"
          ><span>{{ 'vw.collection_page.produit' | t }}</span></a
        >
      </div>
    </div>
  </div>

  <section class="headerCollection">
    <div class="title">
      <h1>
        {{ 'vw.product_page.title_fresque' | t }}
        {{ 'vw.product_page.title_adhesive' | t }}
        <small>180 x 220 cm</small>
        <small>199 €</small>
        <span><small>180 x 220 cm</small></span>
      </h1>
    </div>
  </section>
  <section class="Products">
    {% for collection in collections %}
      {% if collection.handle contains 'jungle'
        or collection.handle contains 'love-women'
        or collection.handle contains 'abstract'
      %}
        <div id="{{ collection.handle }}" class="bgCollection {{ collection.handle }} white notranslate">
          <h2>{{ collection.title }}</h2>
          <ul class="productsList">
            {% for product in collection.products %}
              {% unless product.handle contains 'marketplace' %}
                <li>
                  <div class="sale-icon" style="display:none;">
                    <span>-33%</span>
                  </div>
                  <span>{{ product.title }}</span>
                  <a>
                    <img
                      alt="{{ 'vw.index.slide_collections.carreau_alt' | t }} {{ product.title }} - collection {{ collection.title }}"
                      loading="lazy"
                      src="{{ product.images[1] | img_url: '200x' }}"
                    >
                  </a>
                  <div class="buttons">
                    <a data-href="{{ product.url }}">{{ 'vw.collection_page.produit' | t }}</a>
                    <span id="{% assign current_variant = product.selected_or_first_available_variant %}{{ current_variant.sku }}">
                      <svg
                        version="1.1"
                        xmlns="https://www.w3.org/2000/svg"
                        xmlns:xlink="https://www.w3.org/1999/xlink"
                        x="0px"
                        y="0px"
                        viewBox="0 0 56.966 56.966"
                        style="enable-background:new 0 0 56.966 56.966;"
                        xml:space="preserve"
                      >
                        <path
                            d="M55.146,51.887L41.588,37.786c3.486-4.144,5.396-9.358,5.396-14.786c0-12.682-10.318-23-23-23s-23,10.318-23,23  s10.318,23,23,23c4.761,0,9.298-1.436,13.177-4.162l13.661,14.208c0.571,0.593,1.339,0.92,2.162,0.92  c0.779,0,1.518-0.297,2.079-0.837C56.255,54.982,56.293,53.08,55.146,51.887z M23.984,6c9.374,0,17,7.626,17,17s-7.626,17-17,17  s-17-7.626-17-17S14.61,6,23.984,6z" />
                      </svg>
                    </span>
                  </div>
                </li>
              {% endunless %}
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    {% endfor %}
  </section>
</div>

<script>
         $(document).ready(function() {

         // variables

     let selectedHref = "/products/adhesive-mural-william";

     let resolutionMES = "1200x";
        if ($(window).width() < 600) {
        resolutionMES = "500x";
        }
    let actualBackgroundRoom = $('.popupPreview .popupPreviewContent').css('background-image');

         //changeImageMES

            $(".productsList li > div > span").click(function() {
     let refProduct = this.id.replace("VIR","");
     let smallRefProduct = refProduct.slice(0, 5);
     $(".popupPreview .popupPreviewContent").css("background-image", "url(https://ftp.vinyl-wall.com/vinylway-europe/mes/" + resolutionMES + "/" + smallRefProduct + "-MES.jpg");
     selectedHref = $(this).parent().children('a').data('href');
     $(".popupPreview .popupPreviewContent > div > :nth-child(2)").data("href", selectedHref);
            });

         if (window.innerWidth > 1080) {
           $(".productsList li > a img").hover(function() {
     let refProduct = $(this).closest('li').find('.buttons > span[id^="VIR"]').attr('id').replace("VIR","");
     let smallRefProduct = refProduct.slice(0, 5);
     $(".popupPreview .popupPreviewContent").css("background-image", "url(https://ftp.vinyl-wall.com/vinylway-europe/mes/" + resolutionMES + "/" + smallRefProduct + "-MES.jpg");
     actualBackgroundRoom = $('.popupPreview .popupPreviewContent').css('background-image');
     selectedHref = $(this).closest('li').find('.buttons > span[id^="VIR"]').siblings('a').data('href');
     $(".popupPreview .popupPreviewContent > div > :nth-child(2)").data("href", selectedHref);
  });
         }


         // loadFirstProduct
           if ($(window).width() > 1025) {
         function loadFirstProduct() {
         {% unless collection.handle contains "-couleur" or collection.handle contains "-best" or collection.handle contains "-style" %}
            $(".Products :nth-child(1) .productsList :nth-child(1) > div > span").trigger('click');
           {% else %}
            $(".Products .productsList :nth-child(1) > div > span").trigger('click');
           {% endunless %}
         }
         loadFirstProduct();
           }


         // productHref
           $(".Products .productsList li > div > a").click(function() {
            let dataHref = $(this).data('href');
            location.href = dataHref;
          });
           $(".Products .productsList li > a").click(function() {
            let dataHref = $(this).parent().find("div").find("a").data('href');
            location.href = dataHref;
          });
           $(".popupPreview .popupPreviewContent > div > :nth-child(2)").click(function() {
            let dataHref = $(this).data('href');
            location.href = dataHref;
          });

           });
</script>
