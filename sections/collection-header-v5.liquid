{% comment %}
  Section: Vinyl Way Header V5.40 - ÉPURÉ
  Description: 
  - Header Hero avec Trust Bar intégrée en overlay
  - Social Proof (Trustpilot + Prix)
  - Sticky Nav seule avec recherche
  Author: Architecte UX pour Vinyl Way
{% endcomment %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap');

  :root {
    --vw-green: #235c52;
    --vw-green-light: #2d7a6d;
    --vw-black: #111827;
    --vw-white: #ffffff;
    --vw-border: #e5e7eb;
  }

  .vw-global-header {
    background: var(--vw-white);
    font-family: 'Inter', sans-serif;
    padding-bottom: 0;
    position: relative;
    z-index: 1;
  }

  /* HERO */
  .vw-hero-main {
    position: relative;
    min-height: 50vh; 
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-size: cover;
    background-position: center;
    color: white;
    margin-bottom: 0;
    padding-bottom: 5rem;
    z-index: 1;
  }
  .vw-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.55) 100%);
    z-index: 1;
  }
  .vw-hero-content {
    position: relative; z-index: 2;
    padding: 3rem 1rem 2rem;
    max-width: 900px;
  }

  /* TITRES */
  .vw-main-title {
    font-family: 'Playfair Display', serif; font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1; margin: 0 0 1rem; color: white;
    text-shadow: 0 2px 10px rgba(0,0,0,0.15); 
  }
  .vw-main-desc {
    font-size: 1rem; line-height: 1.6; color: rgba(255,255,255,0.95);
    max-width: 600px; margin: 0 auto 1.5rem; font-weight: 400;
  }

  /* SOCIAL PROOF HERO */
  .vw-hero-social-proof {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .vw-trustpilot-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(10px);
    padding: 10px 20px;
    border-radius: 50px;
    border: 1px solid rgba(255,255,255,0.25);
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .vw-trustpilot-badge:hover {
    background: rgba(255,255,255,0.25);
    transform: translateY(-2px);
  }
  .vw-trustpilot-stars {
    display: flex;
    gap: 2px;
  }
  .vw-trustpilot-stars svg {
    width: 16px;
    height: 16px;
  }
  .vw-star-half {
    position: relative;
    width: 16px;
    height: 16px;
  }
  .vw-star-half svg {
    position: absolute;
    top: 0;
    left: 0;
  }
  .vw-star-half .vw-star-bg {
    color: rgba(255,255,255,0.3);
  }
  .vw-star-half .vw-star-fill {
    clip-path: inset(0 50% 0 0);
  }
  .vw-trustpilot-text {
    font-size: 0.8rem;
    font-weight: 600;
    color: white;
  }

  /* TRUST BAR DANS LE HERO */
  .vw-trust-strip-hero {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 0 1rem;
  }
  .vw-trust-grid-hero {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
    padding: 1.2rem 1rem;
    position: relative;
  }
  .vw-trust-grid-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    max-width: 500px;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.4) 20%, rgba(255,255,255,0.4) 80%, transparent 100%);
  }
  .vw-trust-unit-hero {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .vw-trust-icon-hero {
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    opacity: 0.9;
    flex-shrink: 0;
  }
  .vw-trust-icon-hero svg, .vw-trust-icon-hero img { 
    width: 100%; 
    height: 100%; 
    object-fit: contain; 
  }
  .vw-trust-label-hero {
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: white;
    white-space: nowrap;
  }

  /* STICKY NAV AVEC RECHERCHE */
  .vw-sticky-nav {
    position: sticky; top: 0; z-index: 50;
    background: var(--vw-white);
    border-bottom: 1px solid var(--vw-border);
    padding: 0;
    box-shadow: 0 2px 15px rgba(0,0,0,0.06);
    transition: all 0.3s ease;
  }
  .vw-sticky-nav.scrolled {
    box-shadow: 0 4px 25px rgba(0,0,0,0.1);
  }
  .vw-sticky-nav-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    gap: 0.5rem;
  }
  .vw-nav-scroll {
    overflow-x: auto;
    white-space: nowrap;
    flex: 1;
    display: flex;
    justify-content: center;
  }
  .vw-nav-scroll::-webkit-scrollbar { display: none; }
  .vw-nav-scroll { -ms-overflow-style: none; scrollbar-width: none; }
  .vw-nav-list { 
    display: flex; 
    justify-content: center; 
    gap: 0; 
    min-width: max-content;
  }
  .vw-nav-link {
    font-family: 'Inter', sans-serif; 
    font-size: 0.85rem; 
    font-weight: 600;
    text-transform: uppercase; 
    letter-spacing: 0.03em; 
    color: #6b7280;
    text-decoration: none; 
    padding: 1rem 1.5rem; 
    position: relative; 
    transition: all 0.3s;
    border-bottom: 3px solid transparent;
  }
  .vw-nav-link:hover { 
    color: var(--vw-green);
    background: rgba(35, 92, 82, 0.05);
  }
  .vw-nav-link.active {
    color: var(--vw-green);
    border-bottom-color: var(--vw-green);
    background: rgba(35, 92, 82, 0.05);
  }

  /* BOUTON RECHERCHE */
  .vw-search-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    color: #6b7280;
    cursor: pointer;
    border-radius: 8px;
    transition: all 0.3s ease;
    flex-shrink: 0;
  }
  .vw-search-toggle:hover {
    background: rgba(35, 92, 82, 0.1);
    color: var(--vw-green);
  }
  .vw-search-toggle svg {
    width: 20px;
    height: 20px;
  }

  /* BARRE DE RECHERCHE */
  .vw-search-bar {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--vw-white);
    border-bottom: 2px solid var(--vw-green);
    padding: 1rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    transform: translateY(-10px);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    z-index: 100;
  }
  .vw-search-bar.open {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }
  .vw-search-container {
    max-width: 600px;
    margin: 0 auto;
    position: relative;
  }
  .vw-search-input {
    width: 100%;
    padding: 14px 50px 14px 20px;
    border: 2px solid var(--vw-border);
    border-radius: 50px;
    font-size: 1rem;
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: border-color 0.3s ease;
  }
  .vw-search-input:focus {
    border-color: var(--vw-green);
  }
  .vw-search-input::placeholder {
    color: #9ca3af;
  }
  .vw-search-submit {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border: none;
    background: var(--vw-green);
    color: white;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }
  .vw-search-submit:hover {
    background: var(--vw-green-light);
  }
  .vw-search-submit svg {
    width: 18px;
    height: 18px;
  }
  .vw-search-close {
    position: absolute;
    right: -50px;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    border: none;
    background: transparent;
    color: #6b7280;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: all 0.3s ease;
  }
  .vw-search-close:hover {
    background: #f3f4f6;
    color: var(--vw-black);
  }
  
  @media (max-width: 767px) {
    .vw-hero-main { min-height: 50vh; padding-bottom: 4rem; z-index: 1; }
    .vw-hero-content { padding: 2rem 1rem 1rem; }
    .vw-main-title { font-size: 2.2rem; }
    .vw-main-desc { font-size: 0.9rem; margin-bottom: 1rem; }
    .vw-trust-strip-hero { padding: 0 0.5rem; }
    .vw-trust-grid-hero { 
      display: flex;
      justify-content: space-between;
      gap: 0.4rem; 
      padding: 0.7rem 0.25rem;
      max-width: 100%;
    }
    .vw-trust-grid-hero::before {
      width: 90%;
      max-width: 320px;
    }
    .vw-trust-unit-hero { 
      flex-shrink: 0;
      gap: 4px;
    }
    .vw-trust-label-hero { font-size: 0.45rem; letter-spacing: 0; }
    .vw-trust-icon-hero { width: 12px; height: 12px; }
    .vw-nav-scroll { justify-content: flex-start; }
    .vw-nav-link { padding: 0.8rem 1rem; font-size: 0.75rem; }
    .vw-hero-social-proof { gap: 0.8rem; }
    .vw-trustpilot-badge { padding: 8px 14px; }
    .vw-trustpilot-text { font-size: 0.75rem; }
    .vw-search-close { right: 10px; top: -40px; transform: none; }
  }
{% endstyle %}

<div class="vw-global-header">
  
  <!-- HERO -->
  <div class="vw-hero-main" 
       style="background-image: url('{% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 2000 }}{% else %}https://cdn.shopify.com/s/files/1/0554/3382/2364/files/kitchen-splashback.jpg{% endif %}');">
    <div class="vw-hero-overlay"></div>
    
    <div class="vw-hero-content">
      <h1 class="vw-main-title">{{ section.settings.title }}</h1>
      {%- if section.settings.description != blank -%}
        <div class="vw-main-desc">{{ section.settings.description }}</div>
      {%- endif -%}
      
      <!-- SOCIAL PROOF -->
      <div class="vw-hero-social-proof">
        {%- if section.settings.show_trustpilot -%}
        <a href="https://trustpilot.com/review/vinyl-way.com" target="_blank" class="vw-trustpilot-badge">
          <div class="vw-trustpilot-stars">
            {%- comment -%} 4 étoiles pleines {%- endcomment -%}
            {%- for i in (1..4) -%}
            <svg viewBox="0 0 24 24" fill="#00b67a">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            {%- endfor -%}
            {%- comment -%} 1 demi-étoile {%- endcomment -%}
            <span class="vw-star-half">
              <svg viewBox="0 0 24 24" fill="rgba(255,255,255,0.3)" class="vw-star-bg">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              <svg viewBox="0 0 24 24" fill="#00b67a" class="vw-star-fill">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            </span>
          </div>
          <span class="vw-trustpilot-text">{{ section.settings.trustpilot_score | default: '4.4/5' }} Trustpilot</span>
        </a>
        {%- endif -%}
      </div>
    </div>

    <!-- TRUST BAR INTÉGRÉE AU HERO (4 éléments) -->
    {%- if section.settings.show_trust -%}
    <div class="vw-trust-strip-hero">
      <div class="vw-trust-grid-hero">
        
        <!-- Item 1: Made in France -->
        <div class="vw-trust-unit-hero">
          <div class="vw-trust-icon-hero">
            {%- if section.settings.icon_1 != blank -%}
              {{ section.settings.icon_1 | image_url: width: 48 | image_tag }}
            {%- else -%}
              <svg viewBox="0 0 30 20" xmlns="http://www.w3.org/2000/svg">
                <rect width="30" height="20" fill="#ED2939"/>
                <rect width="20" height="20" fill="#fff"/>
                <rect width="10" height="20" fill="#002395"/>
              </svg>
            {%- endif -%}
          </div>
          <span class="vw-trust-label-hero">{{ section.settings.text_1 | default: 'Made in France' }}</span>
        </div>

        <!-- Item 2: Waterproof -->
        <div class="vw-trust-unit-hero">
          <div class="vw-trust-icon-hero">
            {%- if section.settings.icon_2 != blank -%}
              {{ section.settings.icon_2 | image_url: width: 48 | image_tag }}
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>
            {%- endif -%}
          </div>
          <span class="vw-trust-label-hero">{{ section.settings.text_2 | default: 'Waterproof' }}</span>
        </div>

        <!-- Item 3: Épais -->
        <div class="vw-trust-unit-hero">
          <div class="vw-trust-icon-hero">
            {%- if section.settings.icon_3 != blank -%}
              {{ section.settings.icon_3 | image_url: width: 48 | image_tag }}
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7L12 12L22 7L12 2Z" />
                <path d="M2 12L12 17L22 12" />
                <path d="M2 17L12 22L22 17" />
              </svg>
            {%- endif -%}
          </div>
          <span class="vw-trust-label-hero">{{ section.settings.text_3 | default: 'Épais' }}</span>
        </div>

        <!-- Item 4: Garantie -->
        <div class="vw-trust-unit-hero">
          <div class="vw-trust-icon-hero">
            {%- if section.settings.icon_4 != blank -%}
              {{ section.settings.icon_4 | image_url: width: 48 | image_tag }}
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="m9 12 2 2 4-4"/>
              </svg>
            {%- endif -%}
          </div>
          <span class="vw-trust-label-hero">{{ section.settings.text_4 | default: 'Satisfait ou Remboursé' }}</span>
        </div>

      </div>
    </div>
    {%- endif -%}
  </div>

  <!-- STICKY NAV AVEC RECHERCHE -->
  {%- if section.blocks.size > 0 -%}
  <div class="vw-sticky-nav" id="vw-sticky-nav">
    <div class="vw-sticky-nav-inner">
      <div class="vw-nav-scroll">
        <div class="vw-nav-list">
          {%- for block in section.blocks -%}
            <a href="#{{ block.settings.anchor_id }}" class="vw-nav-link" data-target="{{ block.settings.anchor_id }}">{{ block.settings.title }}</a>
          {%- endfor -%}
        </div>
      </div>
      
      <!-- Bouton Recherche -->
      <button class="vw-search-toggle" id="vw-search-toggle" aria-label="Rechercher">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
    </div>

    <!-- Barre de recherche déroulante -->
    <div class="vw-search-bar" id="vw-search-bar">
      <form action="/search" method="get" class="vw-search-container">
        <input 
          type="text" 
          name="q" 
          class="vw-search-input" 
          placeholder="Rechercher un style, une couleur, une collection..."
          autocomplete="off"
          id="vw-search-input"
        >
        <input type="hidden" name="type" value="product">
        <button type="submit" class="vw-search-submit" aria-label="Lancer la recherche">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
        <button type="button" class="vw-search-close" id="vw-search-close" aria-label="Fermer la recherche">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 6 6 18"/>
            <path d="m6 6 12 12"/>
          </svg>
        </button>
      </form>
    </div>
  </div>
  {%- endif -%}

</div>

<!-- JS -->
<script>
document.addEventListener("DOMContentLoaded", function() {
  const navLinks = document.querySelectorAll('.vw-nav-link');
  const stickyNav = document.getElementById('vw-sticky-nav');
  const searchToggle = document.getElementById('vw-search-toggle');
  const searchBar = document.getElementById('vw-search-bar');
  const searchClose = document.getElementById('vw-search-close');
  const searchInput = document.getElementById('vw-search-input');
  const sections = [];
  
  // Collecter toutes les sections cibles
  navLinks.forEach(link => {
    const targetId = link.getAttribute('data-target');
    const section = document.getElementById(targetId);
    if (section) {
      sections.push({ id: targetId, element: section });
    }
  });

  // Smooth scroll
  navLinks.forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      const targetId = this.getAttribute('href').replace('#', '');
      const targetSection = document.getElementById(targetId);
      if(targetSection) {
        const offset = 80; 
        const elementPosition = targetSection.getBoundingClientRect().top + window.pageYOffset;
        const offsetPosition = elementPosition - offset;
        window.scrollTo({ top: offsetPosition, behavior: "smooth" });
      }
    });
  });

  // Indicateur de section active au scroll
  function updateActiveSection() {
    const scrollPosition = window.scrollY + 120;
    
    let activeSection = null;
    sections.forEach(section => {
      const sectionTop = section.element.offsetTop;
      const sectionBottom = sectionTop + section.element.offsetHeight;
      
      if (scrollPosition >= sectionTop && scrollPosition < sectionBottom) {
        activeSection = section.id;
      }
    });

    navLinks.forEach(link => {
      if (link.getAttribute('data-target') === activeSection) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });

    // Ombre sur sticky nav au scroll
    if (stickyNav && window.scrollY > 50) {
      stickyNav.classList.add('scrolled');
    } else if (stickyNav) {
      stickyNav.classList.remove('scrolled');
    }
  }

  // Throttle pour performance
  let ticking = false;
  window.addEventListener('scroll', function() {
    if (!ticking) {
      window.requestAnimationFrame(function() {
        updateActiveSection();
        ticking = false;
      });
      ticking = true;
    }
  });

  // Recherche toggle
  if (searchToggle && searchBar) {
    searchToggle.addEventListener('click', function() {
      searchBar.classList.toggle('open');
      if (searchBar.classList.contains('open') && searchInput) {
        setTimeout(() => searchInput.focus(), 100);
      }
    });
  }

  if (searchClose && searchBar) {
    searchClose.addEventListener('click', function() {
      searchBar.classList.remove('open');
    });
  }

  // Fermer avec Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && searchBar && searchBar.classList.contains('open')) {
      searchBar.classList.remove('open');
    }
  });

  // Initial check
  updateActiveSection();
});
</script>

{% schema %}
{
  "name": "En-tête Global V5.45",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image de fond Hero" },
    { "type": "text", "id": "title", "label": "Titre Principal", "default": "Carreaux Adhésifs" },
    { "type": "textarea", "id": "description", "label": "Description" },
    
    { "type": "header", "content": "Social Proof" },
    { "type": "checkbox", "id": "show_trustpilot", "label": "Afficher Trustpilot", "default": true },
    { "type": "text", "id": "trustpilot_score", "label": "Score Trustpilot", "default": "4.4/5" },

    { "type": "header", "content": "Barre de réassurance" },
    { "type": "checkbox", "id": "show_trust", "label": "Afficher la barre de réassurance", "default": true },
    
    { "type": "header", "content": "Atout 1" },
    { "type": "text", "id": "text_1", "label": "Texte", "default": "Made in France" },
    { "type": "image_picker", "id": "icon_1", "label": "Icône (Optionnel)" },

    { "type": "header", "content": "Atout 2" },
    { "type": "text", "id": "text_2", "label": "Texte", "default": "Waterproof" },
    { "type": "image_picker", "id": "icon_2", "label": "Icône (Optionnel)" },

