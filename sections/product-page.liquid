{{ 'main-product-page.css' | asset_url | stylesheet_tag }}
{{ 'main-product-page.js' | asset_url | script_tag }}


{% capture requestPath %}{{ request.path }}{% endcapture %}



{% if request.locale.iso_code contains "fr" %}
      {% assign localUrl = "" %}
    {% else %}
      {% capture localUrl %}/{{ request.locale.iso_code }}{% endcapture %}
    {% endif %}

{% if product.handle contains 'cadeau' %}
  {% render 'product-gift' %}
{% else %}

{% if product.handle contains '-tiles' %}
  {% assign productType = "tile" %}
  {% elsif product.handle contains '-mural' %}
  {% assign productType = "mural" %}
  {% elsif product.handle contains '-backsplash' %}
  {% assign productType = "backsplash" %}
  {% elsif product.handle contains 'papier-peint' %}
  {% assign productType = "papier_peint" %}
  <style> 
  .list-ship {
    background: #f5f5f5;
    padding: 20px;
    justify-content: space-between;
  }
  </style>
  {% endif %}
  
  {% unless customer and customer.tags contains 'pro' %}
  {% else %}
    {% assign customerPro = true %}
  {% endunless %}

  {% for tag in product.tags %}
    {% if tag contains 'motifs_1' %}
      {% assign nbMotifs = 1 %}
    {% elsif tag contains 'motifs_2' %}
      {% assign nbMotifs = 2 %}
    {% elsif tag contains 'motifs_4' %}
      {% assign nbMotifs = 4 %}
    {% elsif tag contains 'motifs_8' %}
      {% assign nbMotifs = 8 %}
    {% endif %}
  {% endfor %}

<select style="display:none;" name="id" id="variant-select">
  {% for variant in product.variants %}
    <option value="{{ variant.option1 }}-{{ variant.option2 }}-{{ variant.option3 }}" id="{{ variant.id }}" data-price="{% if customerPro %}{{ variant.price | times : 0.7 | money_without_currency }}{% else %}{{ variant.price | money_without_currency }}{% endif %}" data-compare-price="{{ variant.price | money_without_currency }}">{{ variant.title }}</option>
  {% endfor %}
</select>

