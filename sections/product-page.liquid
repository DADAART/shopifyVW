  <div class="contentProductContainer">
    <section class="contentProduct">
      {% if productType =='papier_peint' %}
        {% assign title_parts = product.title | split: '"' %}
      <h1>{{ title_parts[1] }}</h1>
        {% else %}
      <h1 class="notranslate">
        {{ product.title }}
      </h1>
        {% endif %}
  
      {% if productType =='tile' %}
      <h2 class="notranslate">
        <strong>{{ 'vw.product_page.title_carreau' | t }}</strong> {{ 'vw.product_page.title_adhesif' | t }}
     </h2>
        {% elsif productType =='backsplash' %}
      <h2>
        <strong>Crédence</strong> adhésive
        <br>
        <small>40 x 198 cm</small>
     </h2>
        {% elsif productType =='papier_peint' %}
      <h2>
        <strong>Papier peint</strong> adhésif
        <br>
        <small>200 x 250 cm</small>
     </h2>
        {% else %}
      <h2 class="notranslate">
        <strong>{{ 'vw.product_page.title_fresque' | t }}</strong> {{ 'vw.product_page.title_adhesive' | t }}
        <br>
        <small>180 x 220 cm</small>
     </h2>
      {% endif %}

      <div class="grc-product-summary" data-product-id="{{product.id}}"></div>

      {% if productType != 'papier_peint' and product.description != blank %}
      <div class="product-description">
        {{ product.description }}
      </div>
      {% endif %}

      {% if productType == 'papier_peint' %}
      <div id="product-description">
  {{ product.description }}
</div>
<script>
document.addEventListener("DOMContentLoaded", function() {
  // Sélectionner l'élément de description du produit
  var descriptionElement = document.getElementById('product-description');
  
  // Vérifier si l'élément existe
  if (descriptionElement) {
    // Récupérer le contenu texte de la description
    var rawHTML = descriptionElement.textContent;
    
    // Remplacer le contenu texte par le HTML interprété
    descriptionElement.innerHTML = rawHTML;
  }
});

        </script>
