   {% if customer and customer.tags contains "pro"  %}
    (function loadVariantPro(){      
  let selectedOption = $('#variant-select option:selected').text();
  if (selectedOption.indexOf('20x20') !== -1) {
    $('#variant-select').val('20x20-8-HT').change();
  } else if (selectedOption.indexOf('40x40') !== -1) {
    $('#variant-select').val('40x40-4-HT').change();
  } else if (selectedOption.indexOf('180x220') !== -1) {
    $('#variant-select').val('180x220-1-HT').change();
  }
  displayPrice();
})();

